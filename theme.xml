<theme>
  <formatVersion>7</formatVersion>

    <view name="screen">
	
    <controllerActivity name="controllerActivity">
      <pos>0.832 0.025</pos>
      <size>0.085 0.025</size>
      <horizontalAlignment>right</horizontalAlignment>
      <itemSpacing>0.003</itemSpacing>
      <imagePath>./assets/gamepad.svg</imagePath>
      <color>FFFFFF80</color>
      <activityColor>A0A0FFC0</activityColor>
      <hotkeyColor>FFA0A0C0</hotkeyColor>
    </controllerActivity>
	
  </view>
  
  <view name="menu">

    <textlist name="menulist">
      <scrollSound>./sounds/scroll.wav</scrollSound>
      <selectSound>./sounds/select.wav</selectSound>
      <backSound>./sounds/back.wav</backSound>
      <launchSound>./sounds/launch.wav</launchSound>
    </textlist>
  
    <menuText name="menutitle">
      <fontPath>./assets/SST.ttf</fontPath>
      <fontSize>0.044</fontSize>
      <color>ffffff</color>
    </menuText>
	
    <menuText name="menufooter">
      <fontPath>./assets/SST.ttf</fontPath>
      <fontSize>0.02</fontSize>
    </menuText>
	
    <menuText name="menutext">
      <fontPath>./assets/SST.ttf</fontPath>
      <fontSize>0.038</fontSize>
      <color>A6C6D1</color>
      <selectorColor>0F85A5</selectorColor>
      <selectorColorEnd>0F6585</selectorColorEnd>
      <selectedColor>ffffff</selectedColor>
      <separatorColor>00000000</separatorColor>
    </menuText>
	
    <menuTextSmall name="menutextsmall">
      <fontPath>./assets/SST.ttf</fontPath>
      <fontSize>0.02</fontSize>
    </menuTextSmall>
	
    <menuBackground name="menubg">
      <color>00000000</color>
      <cornerSize>0 0</cornerSize>
      <path></path>
    </menuBackground>
	
  </view>

    <view name="system, basic, detailed, grid">
  
      <image name="staticBackground">
       <size>1 1</size>
       <pos>0 0</pos>
       <origin>0 0</origin>
       <scrollSound>./sounds/scroll.wav</scrollSound>
      <selectSound>./sounds/select.wav</selectSound>
      <backSound>./sounds/back.wav</backSound>
      <launchSound>./sounds/launch.wav</launchSound>
       <tile>false</tile>
       <linearSmooth>true</linearSmooth>
       <path>./assets/bg.png</path>
       <zIndex>0</zIndex>
       <color>10667f</color>
     </image>

  </view>

  
  <view name="system">
  
    <image name="staticBackground">
      <size>1 1</size>
      <pos>0 0</pos>
      <origin>0 0</origin>
      <tile>false</tile>
      <linearSmooth>true</linearSmooth>
      <path>./assets/bg.png</path>
      <zIndex>0</zIndex>
      <color>10667f</color>
    </image>
	
    <image name="logo">
      <path>./art/${system.theme}.svg</path>
	  <path>./art/${system.theme}.png</path>
      <reflexion>0 0</reflexion>
      <reflexionOnFrame>false</reflexionOnFrame>
    </image>
	
    <text name="logoText">
      <fontPath>./assets/SST.ttf</fontPath>
      <fontSize>0.092</fontSize>
      <color>FFFFFFFF</color>
      <reflexion>0 0</reflexion>
      <reflexionOnFrame>false</reflexionOnFrame>
    </text>
	
  </view>
  
  <view name="basic">
  
    <image name="blackbg" extra="true">
      <pos>0 0</pos>
      <size>1 1</size>
      <origin>0 0</origin>
      <maxSize>1 1</maxSize>
      <path>./assets/black.png</path>
    </image>
		
  </view>
  
  <view name="basic, detailed, grid">
	
    <image name="blackbg" extra="true">
      <size>1 1</size>
      <pos>0 0</pos>
      <origin>0 0</origin>
      <color>000000FF</color>
      <zIndex>0</zIndex>
    </image>
	
    <image name="background" extra="true">
      <size>1 1</size>
      <pos>0 0</pos>
      <origin>0 0</origin>
      <path>./assets/bg.png</path>
      <zIndex>1</zIndex>
      <color>00000000</color>
    </image>
	
    <text name="system_name" extra="true">
      <text>${system.fullName}</text>
      <forceUppercase>0</forceUppercase>
      <size>0.5 0.025</size>
      <pos>0.02 0.025</pos>
      <color>ffffff</color>
      <fontPath>./assets/SST.ttf</fontPath>
      <fontSize>0.04</fontSize>
      <zIndex>3</zIndex>
    </text>
	
    <text name="md_lbl_genre, md_genre, md_lbl_rating, md_lbl_developer, md_lbl_publisher, md_publisher, md_lbl_lastplayed, md_lbl_playcount, md_playcount, md_lbl_releasedate">
      <visible>false</visible>
    </text>
	
    <rating name="md_rating">
      <visible>false</visible>
    </rating>
	
    <image name="md_thumbnail">
      <visible>false</visible>
      <origin>0.5 0.5</origin>
      <pos>0.5 0.5</pos>
      <minSize>1.25 1.25</minSize>
      <color>FFFFFF0A</color>
    </image>
	
    <video name="md_video">
      <origin>0.5 0.5</origin>
      <pos>0.776 0.388</pos>
      <maxSize>0 0</maxSize>
      <delay>0.7</delay>
      <showSnapshotNoVideo>true</showSnapshotNoVideo>
      <showSnapshotDelay>true</showSnapshotDelay>
      <snapshotSource>image</snapshotSource>
	  <effect>none</effect>
    </video>
	
    <text name="md_description">
      <pos>0.605 0.685</pos>
      <size>0.347 0.183</size>
      <color>ffffff</color>
      <fontSize>0.025</fontSize>
      <fontPath>./assets/SST.ttf</fontPath>

    </text>
	
    <image name="logo">
      <pos>1 1</pos>
      <color>00000000</color>
      <path>./assets/box.png</path>
    </image>
	
  </view>
  
  <view name="basic,detailed">
    <textlist name="gamelist">
      <selectorColor>0f85a5</selectorColor>
      <selectorColorEnd>0F6585</selectorColorEnd>
      <selectedColor>ffffff</selectedColor>
      <primaryColor>ffffff</primaryColor>
      <secondaryColor>ffffff</secondaryColor>
      <fontPath>./assets/SST.ttf</fontPath>
      <fontSize>0.03</fontSize>
      <pos>0.051 0.170</pos>
      <scrollSound>./sounds/scroll.wav</scrollSound>
      <selectSound>./sounds/select.wav</selectSound>
      <backSound>./sounds/back.wav</backSound>
      <launchSound>./sounds/launch.wav</launchSound>      
      <size>0.50 0.70</size>
      <alignment>left</alignment>
      <horizontalMargin>0.01</horizontalMargin>
      <origin>0 0</origin>
      <lineSpacing>2.1</lineSpacing>
      <selectorImagePath>./assets/box.png</selectorImagePath>
      <selectorOffsetY>-0.01</selectorOffsetY>
      <selectorHeight>0.0675</selectorHeight>
    </textlist>
  </view>
  
  <view name="grid">
    <image name="md_image">
      <visible>false</visible>
    </image>
	
    <text name="md_lbl_rating, md_lbl_releasedate, md_lbl_developer, md_lbl_publisher, md_lbl_genre, md_lbl_players, md_lbl_lastplayed, md_lbl_playcount">
      <color>00000000</color>
    </text>
	
    <text name="md_developer, md_publisher, md_genre, md_players, md_playcount">
      <color>00000000</color>
    </text>
	
    <datetime name="md_releasedate, md_lastplayed">
      <color>00000000</color>
    </datetime>
	
    <text name="md_rating">
      <pos>0.88 0.88</pos>
      <size>0.05 0.03</size>
    </text>
	
    <text name="md_name">
      <color>ffffffff</color>
      <pos>0.051 0.16</pos>
      <size>0.50 0.07</size>
      <alignment>center</alignment>
      <glowColor>00000005</glowColor>
      <glowSize>3</glowSize>
    </text>
	
    <imagegrid name="gamegrid">
      <pos>0.047 0.200</pos>
      <size>0.51 0.67</size>
      <margin>0.005 0.010</margin>
      <padding>0.03 0.05 0.03 0.04</padding>
      <autoLayout>3 1</autoLayout>
      <autoLayoutSelectedZoom>1.40</autoLayoutSelectedZoom>
      <animateSelection>false</animateSelection>
      <scrollDirection>horizontal</scrollDirection>
      <centerSelection>true</centerSelection>
      <scrollLoop>true</scrollLoop>
    </imagegrid>
	
    <gridtile name="default">
      <backgroundColor>FFFFFF00</backgroundColor>
      <backgroundCornerSize>9 9</backgroundCornerSize>
      <selectionMode>image</selectionMode>
      <padding>5 5</padding>
      <imageColor>FFFFFF90</imageColor>
      <reflexion>0 0</reflexion>
    </gridtile>
	
    <gridtile name="selected">
      <backgroundColor>FFFFFF00</backgroundColor>
      <imageColor>FFFFFFFF</imageColor>
    </gridtile>
  </view>
  
  <view name="system">
  
<carousel name="systemcarousel">
      <type>horizontal_wheel</type>
      <pos>0 0</pos>
      <size>1 1</size>
      <origin>0 0</origin>
      <color>00000000</color>
      <logoScale>2.5</logoScale>
      <logoSize>0.25 0.155</logoSize>
      <logoPos>0.375 0.5</logoPos>
      <logoRotation>7.5</logoRotation>
      <logoRotationOrigin>0.5 44</logoRotationOrigin>
      <logoAlignment>center</logoAlignment>
      <maxLogoCount>5</maxLogoCount>
      <scrollSound>./sounds/scroll.wav</scrollSound>
      <selectSound>./sounds/select.wav</selectSound>
      <backSound>./sounds/back.wav</backSound>
      <launchSound>./sounds/launch.wav</launchSound>
</carousel>

	
    <text name="systemInfo">
      <scrollSound>./sounds/scroll.wav</scrollSound>
      <selectSound>./sounds/select.wav</selectSound>
      <backSound>./sounds/back.wav</backSound>
      <launchSound>./sounds/launch.wav</launchSound>
      <pos>0 0.87</pos>
      <size>1 0.06</size>
      <alignment>center</alignment>
      <fontPath>./assets/SST.ttf</fontPath>
      <fontSize>0.045</fontSize>
      <color>ffffff</color>
      <backgroundColor>00000000</backgroundColor>
    </text>
	
  </view>
  
  <variables>
<fullscreenfixSubsetname>Screen Size</fullscreenfixSubsetname>
<backgroundSubsetName>Internal Theme</backgroundSubsetName>
<imageTypeName>Icon Style</imageTypeName>
<contrastName>Contrast Color</contrastName>
<gamelistModeName>Gamelist Position</gamelistModeName>
<menuImagesName>Menu Transparency</menuImagesName>
<selectionName>Selection Color</selectionName>
<BoostName>Minimal System View</BoostName>
<portrayTypeName>Icon Layout</portrayTypeName>
</variables>


<subset name="fullscreenfix" displayName="${fullscreenfixSubsetname}">
<include name="4:3">./fullscreenv.xml</include>
<include name="Fill"/>
<include name="Fullscreen">./fullscreen.xml</include>
</subset>

<subset name="background" displayName="${backgroundSubsetName}">
<include name="portal">./assets/bg2.xml</include>
<include name="landscape">./assets/bg4.xml</include>
<include name="disc">./assets/bg1.xml</include>
<include name="desktop">./assets/bg3.xml</include>
<include name="shelves">./assets/bg5.xml</include>
<include name="terminal">./assets/bg6.xml</include>
<include name="pixel os">./assets/bg7.xml</include>
<include name="cityscape">./assets/bg8.xml</include>
<include name="planets">./assets/bg9.xml</include>
<include name="japan sky">./assets/bg10.xml</include>
<include name="monster">./assets/bg11.xml</include>
</subset>


<subset name="imagetype" displayName="${imageTypeName}">
<include name="Console Icons">./imagetype_logos.xml</include>
<include name="Console Images">./imagetype_consoles.xml</include>
<include name="Console Logos"/>
</subset>

<subset name="portraytype" displayName="${portrayTypeName}">
<include name="Themed"/>
<include name="1 Icon">./assets/portraytype.xml</include>
<include name="3 Icons">./assets/portraytype2.xml</include>
</subset>

<subset name="gamelistmode" displayName="${gamelistModeName}">
<include name="Full Terminal">./assets/gamelist_fullt.xml</include>
<include name="Full Themed">./assets/gamelist_full.xml</include>
<include name="Left"/>
<include name="Center">./assets/gamelist_center.xml</include>
<include name="Right">./assets/gamelist_right.xml</include>
</subset>

<subset name="color" displayName="${contrastName}">
<include name="High">./assets/contrast_bright.xml</include>
<include name="None">./assets/contrast_blue.xml</include>
<include name="Purple">./assets/contrast_purple.xml</include>
<include name="Blue"/>
<include name="Red">./assets/contrast_red.xml</include>
<include name="Green">./assets/contrast_green.xml</include>
<include name="Yellow">./assets/contrast_yellow.xml</include>
<include name="Orange">./assets/contrast_orange.xml</include>
<include name="Pink">./assets/contrast_pink.xml</include>
</subset>

<subset name="selection" displayName="${selectionName}">
<include name="Purple">./assets/selection_purple.xml</include>
<include name="Blue"/>
<include name="Red">./assets/selection_red.xml</include>
<include name="Green">./assets/selection_green.xml</include>
<include name="Yellow">./assets/selection_yellow.xml</include>
<include name="Orange">./assets/selection_orange.xml</include>
<include name="Pink">./assets/selection_pink.xml</include>
</subset>

<subset name="menuimages" displayName="${menuImagesName}">
<include name="On"/>
<include name="Off">./menuimages_on.xml</include>
</subset>

<subset name="Boost" displayName="${BoostName}">
<include name="On">./assets/cpumode_on.xml</include>
<include name="Off"/>
</subset>

<view name="basic, detailed, video, grid">
	<sound name="scroll">
		<path>./sounds/scroll.wav</path>
	</sound>
	<sound name="launch">
		<path>./sounds/launch.wav</path>
	</sound>
	<sound name="back">
		<path>./sounds/back.wav</path>
	</sound>
</view>

<view name="system">
	<sound name="scroll">
		<path>./sounds/scroll.wav</path>
	</sound>
	<sound name="launch">
		<path>./sounds/select.wav</path>
	</sound>

</view>

</theme>