<?xml version="1.0" encoding="UTF-8"?>
<theme>
  <formatVersion>7</formatVersion>
  <view name="system">
    <image name="staticBackground">
      <path>./bg5.png</path>
    </image>
    <carousel name="systemcarousel">
      <type>horizontal_wheel</type>
      <pos>0 0</pos>
      <size>1 1</size>
      <origin>0 0</origin>
      <color>00000000</color>
      <logoScale>2</logoScale>
      <logoSize>0.25 0.155</logoSize>
      <logoPos>0.375 0.43</logoPos>
      <logoRotation>5</logoRotation>
      <logoRotationOrigin>0.5 44</logoRotationOrigin>
      <logoAlignment>center</logoAlignment>
      <maxLogoCount>3</maxLogoCount>
    </carousel>
  </view>
  <view name="basic, detailed, grid">
    <text name="system_name">
     <text>${system.fullName}</text>
     <pos>0.03 0.08</pos>
     <size>0.8 0.1</size>
     <alignment>left</alignment>
     <fontSize>0.07</fontSize>
     <color>FFFFFFFF</color>
     <zIndex>10</zIndex>
    </text>

    <image name="background">
       <path>./bg5.png</path>
      <color>10A090</color>
    </image>
  </view>
</theme>
