<theme>

    <view name="system">
        <text name="systemInfo">
            <visible>false</visible>
        </text>

        <carousel name="systemcarousel">
        </carousel>
    </view>

    <!-- 🚫 Disable header + force 4:3 -->
    <subset name="fullscreenfix">
        <include name="4:3">./fullscreenv.xml</include>
    </subset>

  <view name="screen">
    <text name="clock">
      <pos>0.85 -0.11</pos>
      <size>0.07 .2</size>
      <fontSize>0.025</fontSize>
      <color>00000000</color>
      <horizontalAlignment>center</horizontalAlignment>
      <verticalAlignment>center</verticalAlignment>
      <fontPath>./assets/SST.ttf</fontPath>
    </text>

<header name="header">
    <backgroundColor>00000000</backgroundColor>
    <textColor>00000000</textColor>
    <iconColor>00000000</iconColor>
  </header>
  </view>
  
  <view name="system">
    <helpsystem name="help">
	  <textColor>00000000</textColor>
      <iconColor>00000000</iconColor>
      <fontSize>0.025</fontSize>
      <fontPath>./assets/SST.ttf</fontPath>
    </helpsystem>
  </view>
  
  <view name="basic, detailed, grid">
    <helpsystem name="help">
	  <textColor>00000000</textColor>
      <iconColor>00000000</iconColor>
      <fontSize>0.025</fontSize>
      <fontPath>./assets/SST.ttf</fontPath>
    </helpsystem>
  </view>

</theme>